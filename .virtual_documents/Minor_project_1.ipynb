# 1. Gather all data points from your notebook (Before vs After Feature Engineering)
data = {
    "Model": [
        "Logistic Regression (Base)",
        "Logistic Regression (After FE)",
        "KNN (Base)",
        "KNN (After FE)",
        "Naive Bayes (Base)",
        "Naive Bayes (After FE)",
    ],
    "Accuracy": [86.5, 87.5, 77.5, 77.0, 86.5, 86.5],
    "Precision": [78.3, 79.0, 80.8, 66.7, 80.4, 78.3],
    "Recall": [77.0, 80.3, 34.4, 49.2, 73.8, 77.0],
    "F1-Score": [77.7, 79.7, 48.3, 56.6, 76.9, 77.7],
}

df_all = pd.DataFrame(data)


df_melted = df_all.melt(
    id_vars="Model", var_name="Metric", value_name="Percentage"
)


df_melted["Classifier"] = df_melted["Model"].apply(lambda x: x.split(" (")[0])
df_melted["Stage"] = df_melted["Model"].apply(
    lambda x: x.split(" (")[1].replace(")", "")
)


plt.figure(figsize=(14, 7))
sns.set_theme(style="whitegrid")


ax = sns.barplot(
    data=df_melted,
    x="Metric",
    y="Percentage",
    hue="Model",
    palette="Paired",  
)


for container in ax.containers:
    ax.bar_label(container, fmt="%.1f%%", padding=3, fontsize=8, weight="bold")

plt.title(
    "Complete Pipeline Comparison: Impact of Feature Engineering",
    fontsize=16,
    pad=20,
    weight="bold",
)
plt.ylabel("Score (%)", fontsize=12)
plt.xlabel("Evaluation Metrics", fontsize=12)
plt.ylim(0, 115)
plt.legend(title="Model & Optimization Stage", loc="upper left", bbox_to_anchor=(1, 1))
plt.tight_layout()


plt.savefig("feature_engineering_comparison.png", dpi=300, bbox_inches="tight")
plt.show()



